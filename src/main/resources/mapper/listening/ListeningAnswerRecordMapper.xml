<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.andrew.smartielts.listening.mapper.ListeningAnswerRecordMapper">

    <resultMap id="BaseMap" type="com.andrew.smartielts.listening.domain.pojo.ListeningAnswerRecord">
        <id column="id" property="id"/>
        <result column="record_id" property="recordId"/>
        <result column="question_id" property="questionId"/>
        <result column="part_group_id" property="partGroupId"/>
        <result column="user_answer" property="userAnswer"/>
        <result column="normalized_answer" property="normalizedAnswer"/>
        <result column="raw_answers_json" property="rawAnswersJson"/>
        <result column="is_correct" property="isCorrect"/>
        <result column="score" property="score"/>
    </resultMap>

    <insert id="insertListeningAnswerRecord"
            parameterType="com.andrew.smartielts.listening.domain.pojo.ListeningAnswerRecord"
            useGeneratedKeys="true"
            keyProperty="id"
            keyColumn="id">
        INSERT INTO listening_answer_record (
            record_id,
            question_id,
            part_group_id,
            user_answer,
            normalized_answer,
            raw_answers_json,
            is_correct,
            score
        ) VALUES (
                     #{recordId},
                     #{questionId},
                     #{partGroupId},
                     #{userAnswer},
                     #{normalizedAnswer},
                     #{rawAnswersJson},
                     #{isCorrect},
                     #{score}
                 )
    </insert>

    <select id="findByRecordId" resultMap="BaseMap">
        SELECT
            id,
            record_id,
            question_id,
            part_group_id,
            user_answer,
            normalized_answer,
            raw_answers_json,
            is_correct,
            score
        FROM listening_answer_record
        WHERE record_id = #{recordId}
        ORDER BY id ASC
    </select>

</mapper>