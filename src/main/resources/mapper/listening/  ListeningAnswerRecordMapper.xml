<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.andrew.smartielts.listening.mapper.ListeningAnswerRecordMapper">

    <resultMap id="ListeningAnswerRecordMap" type="com.andrew.smartielts.listening.domain.pojo.ListeningAnswerRecord">
        <id property="id" column="id"/>
        <result property="recordId" column="record_id"/>
        <result property="questionId" column="question_id"/>
        <result property="userAnswer" column="user_answer"/>
        <result property="isCorrect" column="is_correct"/>
        <result property="score" column="score"/>
    </resultMap>

    <insert id="insert" parameterType="com.andrew.smartielts.listening.domain.pojo.ListeningAnswerRecord"
            useGeneratedKeys="true" keyProperty="id">
        insert into listening_answer_record (record_id, question_id, user_answer, is_correct, score)
        values (#{recordId}, #{questionId}, #{userAnswer}, #{isCorrect}, #{score})
    </insert>

    <select id="findByRecordId" resultMap="ListeningAnswerRecordMap">
        select id, record_id, question_id, user_answer, is_correct, score
        from listening_answer_record
        where record_id = #{recordId}
        order by id asc
    </select>

</mapper>
